# Browser → dashboard API (see README)
# Same host as the UI (nginx proxies /api to the Go API): use a relative path.
NEXT_PUBLIC_API_BASE=/api/v1
# Split hosts (UI on www, API on api): use an absolute URL at build time, and set API
# CORS_ORIGIN_HOST_SUFFIXES to your registrable domain (e.g. nodedr.com) on the server.
# NEXT_PUBLIC_API_BASE=https://api.example.com/api/v1

# ── Optional: marketing contact form → Nodedr hosted submit API (server-side only)
# Used by POST /api/contact-submit. Never use NEXT_PUBLIC_* for these.
# Public key must start with pk_
nodedrmain_NODEDR_SUBMIT_PUBLIC_KEY=pk_replace_me

# Alternative name (either works):
# NODEDR_PUBLIC_KEY=pk_replace_me
# NODEDR_SUBMIT_PUBLIC_KEY=pk_replace_me

# Optional HMAC signing for upstream (must start with sk_). Set only at runtime (Docker/K8s secrets).
# Do not commit real secret keys.
# nodedrmain_NODEDR_SUBMIT_SECRET_KEY=
# NODEDR_SUBMIT_SECRET_KEY=
