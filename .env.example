# Copy to `.env` in this directory before `docker compose up`.
# Required for docker-compose (no weak defaults).

POSTGRES_PASSWORD=change-me-db-password
JWT_SECRET=replace-with-openssl-rand-hex-32-min-32-chars
RUSTFS_ROOT_PASSWORD=change-me-storage-password

# Optional: HTTPS deployments should use Secure cookies
# AUTH_COOKIE_SECURE=true
