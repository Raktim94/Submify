# Copy to `.env` in this directory before `docker compose up`.
# Required for docker-compose (no weak defaults).

POSTGRES_PASSWORD=change-me-db-password
JWT_SECRET=replace-with-openssl-rand-hex-32-min-32-chars
RUSTFS_ROOT_PASSWORD=change-me-storage-password

# Optional: HTTPS deployments should use Secure cookies
# AUTH_COOKIE_SECURE=true

# When the dashboard and API use different hosts (e.g. https://www.example.com → https://api.example.com),
# allow all origins under your domain for credentialed API calls:
# CORS_ORIGIN_HOST_SUFFIXES=example.com
# (Also set NEXT_PUBLIC_API_BASE on the web image to https://api.example.com/api/v1 — see apps/web/.env.example.)
