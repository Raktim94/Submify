# Optional Compose overrides. Submify runs out of the box without this file:
#   docker compose up --build -d
# Built-in defaults for Postgres / JWT / MinIO are in docker-compose.yml (change them for production).
#
# Copy to `.env` when you need custom secrets or CORS/tunnel/contact-proxy:
#   ./scripts/setup-env.sh
#
# If you use `.env.auto` (from SUBMIFY_GENERATE_AUTO_ENV=1 ./scripts/compose-up.sh), load order is:
#   .env.auto first, then `.env` — keys in `.env` win.

# --- Production: set strong, unique values ---
# POSTGRES_PASSWORD=
# JWT_SECRET=
# RUSTFS_ROOT_PASSWORD=

# AUTH_COOKIE_SECURE=true

# CORS_ORIGIN_HOST_SUFFIXES=example.com
# (Split UI/API hosts: set NEXT_PUBLIC_API_BASE on the web image — see apps/web/.env.example.)
