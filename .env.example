# Copy this file to `.env` before running `docker compose up`.
# Replace values with strong secrets for your environment.
#
# Required runtime secrets.
POSTGRES_PASSWORD=replace-with-strong-db-password
JWT_SECRET=replace-with-strong-jwt-secret
RUSTFS_ROOT_USER=submify
RUSTFS_ROOT_PASSWORD=replace-with-strong-storage-password
#
# Optional network/runtime overrides.
# SUBMIFY_BIND_IP=127.0.0.1
# SUBMIFY_PORT=2512
# REFRESH_TOKEN_TTL_HOURS=24
#
# Optional: set true for HTTPS deployments.
# AUTH_COOKIE_SECURE=true
#
# Optional: when dashboard and API use different hosts.
# CORS_ORIGIN_HOST_SUFFIXES=example.com
# (Also set NEXT_PUBLIC_API_BASE on the web image — see apps/web/.env.example.)
